# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (sin slash final) — magic links y redirects (debe coincidir con Supabase Auth Site URL)
# MVP: dominio Railway; al pasar a dominio propio, actualiza aquí + Supabase Auth + Railway.
SITE_URL=https://affiliads-app-production.up.railway.app

# Producción (Railway)
NODE_ENV=production

# Sentry (opcional; servidor)
SENTRY_DSN=

# Cliente Sentry (build Vite; mismo DSN suele ser público)
VITE_SENTRY_DSN=

# Cifrado at-rest para tokens Meta (AES-256-GCM). Generar: openssl rand -hex 32
ENCRYPTION_KEY=

# Opcional: rotación de clave (misma longitud que ENCRYPTION_KEY)
# ENCRYPTION_KEY_V2=

# Opcional: versión de Graph API (default v21.0)
# META_GRAPH_API_VERSION=v21.0

# Meta App (solo servidor; Ajustes → Básico en developers.facebook.com)
# META_APP_ID=
# META_APP_SECRET=
