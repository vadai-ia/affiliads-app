# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (sin slash final) — magic links y redirects (debe coincidir con Supabase Auth Site URL)
# MVP: usa la URL pública que te da Railway (Settings → Networking → tu dominio .railway.app o custom).
# Ejemplo habitual del servicio affiliads-app:
SITE_URL=https://affiliads-app-production.up.railway.app

# Producción (Railway)
NODE_ENV=production

# Sentry (opcional; servidor)
SENTRY_DSN=

# Cliente Sentry (build Vite; mismo DSN suele ser público)
VITE_SENTRY_DSN=

# Cifrado at-rest para tokens Meta (AES-256-GCM). Generar: openssl rand -hex 32
ENCRYPTION_KEY=

# Opcional: rotación de clave (misma longitud que ENCRYPTION_KEY)
# ENCRYPTION_KEY_V2=

# Opcional: versión de Graph API (default v21.0)
# META_GRAPH_API_VERSION=v21.0

# Meta App (solo servidor; Ajustes → Básico en developers.facebook.com)
# META_APP_ID=
# META_APP_SECRET=

# Resend (emails transaccionales; https://resend.com → API Keys)
RESEND_API_KEY=
# Remitente verificado en Resend (dominio propio). Ej: AfiliAds <notifications@tudominio.com>
EMAIL_FROM=

# Inngest (jobs en background; claves en https://app.inngest.com → tu app → Keys)
# INNGEST_ENV: nombre del entorno en Inngest (debe coincidir con el selector del dashboard).
# En Railway, si lo omites, el SDK usa RAILWAY_GIT_BRANCH (p. ej. main) = branch env, no Production.
# Producción: `production` o el slug que veas en app.inngest.com (p. ej. algunos usan `prod`).
INNGEST_ENV=production
# En "Sync" / app URL, usa la MISMA base que SITE_URL (Railway):
#   https://affiliads-app-production.up.railway.app/api/inngest
# (sustituye el host si Railway te asignó otro dominio)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
